{
  "name": "voice-lab",
  "version": "0.1.0",
  "description": "Archived local-first VoxCPM2 voice cloning experiment.",
  "license": "MIT",
  "scripts": {
    "local": "node scripts/local-dev.mjs",
    "local:check": "node scripts/local-dev.mjs --check",
    "reference:prepare": "tsx scripts/reference-prepare.ts",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "test:voxcpm": "python3 -m unittest services.voxcpm.test_server",
    "check": "npm test && npm run typecheck && npm run build",
    "check:voxcpm": "python3 services/voxcpm/check_runtime.py",
    "check:voxcpm:health": "python3 services/voxcpm/check_health.py",
    "clean": "rm -rf .next .vercel .venv tsconfig.tsbuildinfo output storage .voice-lab runs voice-references debug-artifacts tmp hf-home hf-cache .hf-home .hf-cache model-cache models && find . -name .DS_Store -type f -delete && find . -type d -name __pycache__ -prune -exec rm -rf {} +",
    "analyze-audio": "tsx scripts/analyze-audio.ts"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@next/env": "^16.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
