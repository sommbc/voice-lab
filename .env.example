# Voice Lab local configuration template.
# Copy to .env.local. Never commit .env.local or real secrets.

# Optional. Private local storage root. Leave blank to use ~/.voice-lab.
# Keep this outside the repository because it can contain audio, transcripts, and manifests.
VOICE_LAB_DATA_DIR=

# Optional. Next app mastering strategy: static or speech-leveler.
VOICE_LAB_MASTERING_STRATEGY=static

# Required for generation. Keep false until a private VoxCPM2 service is running.
VOXCPM_ENABLED=false

# Required for generation. Local/private FastAPI VoxCPM2 service endpoint.
VOXCPM_ENDPOINT_URL=http://127.0.0.1:8809/generate

# Optional for checks. Authenticated health endpoint for the same service.
VOXCPM_HEALTH_URL=http://127.0.0.1:8809/health

# Required for generation and health checks. Use a strong local token.
# Leave blank in this example. Never commit a real value.
VOXCPM_API_KEY=

# Optional. native-wrapper is the service in services/voxcpm/server.py.
# vllm-omni is only for compatible private endpoints.
VOXCPM_ENDPOINT_MODE=native-wrapper

# Optional. Hugging Face model id used by the Python service/runtime checks.
VOXCPM_MODEL=openbmb/VoxCPM2

# Optional. Next app request timeout in milliseconds.
VOXCPM_TIMEOUT_MS=300000

# Optional. VoxCPM2 generation controls sent to the service.
VOXCPM_CFG_VALUE=2.0
VOXCPM_INFERENCE_TIMESTEPS=10
VOXCPM_NORMALIZE_TEXT=true
VOXCPM_DENOISE_REFERENCE=false

# Optional. Python service runtime controls.
# VOXCPM_DEVICE is a requested/diagnostic value for runner checks. VoxCPM 2.0.2
# does not accept an explicit device argument and selects cuda, then mps, then cpu internally.
VOXCPM_DEVICE=
VOXCPM_OPTIMIZE=true

# Optional. Needed only when running service-side denoising.
VOXCPM_LOAD_DENOISER=false

# Optional. Hugging Face download/cache settings for the Python service.
# Use HF_TOKEN only when needed for model access or rate limits.
# Keep HF_HOME and HF_HUB_CACHE outside this repository.
HF_TOKEN=
HF_HOME=
HF_HUB_CACHE=
